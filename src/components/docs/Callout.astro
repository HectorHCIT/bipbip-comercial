---
interface Props {
  type: 'info' | 'warning' | 'danger';
}

const { type } = Astro.props;

const styles = {
  info: {
    container: 'border-blue-500/30 bg-blue-50 dark:bg-blue-500/5',
    icon: 'text-blue-500',
    title: 'text-blue-800 dark:text-blue-400',
    path: 'M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z',
  },
  warning: {
    container: 'border-amber-500/30 bg-amber-50 dark:bg-amber-500/5',
    icon: 'text-amber-500',
    title: 'text-amber-800 dark:text-amber-400',
    path: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
  },
  danger: {
    container: 'border-red-500/30 bg-red-50 dark:bg-bipbip-red/5',
    icon: 'text-red-500',
    title: 'text-red-800 dark:text-red-400',
    path: 'M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
};

const s = styles[type];
---

<div class:list={['my-6 rounded-lg border-l-4 p-4', s.container]}>
  <div class="flex gap-3">
    <div class:list={['mt-0.5 shrink-0', s.icon]}>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d={s.path} />
      </svg>
    </div>
    <div>
      <p class:list={['text-sm font-semibold', s.title]}>
        <slot name="title" />
      </p>
      <div class="mt-1 text-sm text-neutral-700 dark:text-neutral-300">
        <slot />
      </div>
    </div>
  </div>
</div>
