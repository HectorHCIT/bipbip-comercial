---
interface Props {
  href: string;
  method?: string;
  class?: string;
}

const { href, method, class: className, ...attrs } = Astro.props;

const methodColors: Record<string, string> = {
  GET: 'bg-green-500/10 text-green-600 dark:text-green-400',
  POST: 'bg-blue-500/10 text-blue-600 dark:text-blue-400',
  PUT: 'bg-amber-500/10 text-amber-600 dark:text-amber-400',
  DELETE: 'bg-red-500/10 text-red-600 dark:text-red-400',
};
---

<li>
  <a
    href={href}
    class:list={[
      'sidebar-link flex items-center gap-2 min-w-0 rounded-md px-3 py-1.5 text-sm text-neutral-600 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-surface-dark-elevated hover:text-neutral-900 dark:hover:text-white transition-colors',
      className,
    ]}
    data-href={href}
    {...attrs}
  >
    {method && (
      <span class:list={['inline-flex shrink-0 min-w-[2.75rem] justify-center rounded px-1.5 py-0.5 text-[10px] font-bold font-mono', methodColors[method]]}>
        {method}
      </span>
    )}
    <span class="min-w-0 flex-1 truncate">
      <slot />
    </span>
  </a>
</li>
