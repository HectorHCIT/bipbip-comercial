---
interface Tab {
  label: string;
  filename: string;
  code: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
const groupId = `tabbed-${Math.random().toString(36).slice(2, 9)}`;
---

<div data-tabbed-group={groupId} class="rounded-xl border border-neutral-200 dark:border-border-dark bg-neutral-50 dark:bg-surface-dark-raised overflow-hidden my-6">
  <!-- Tab bar -->
  <div class="flex items-center border-b border-neutral-200 dark:border-border-dark bg-neutral-100/50 dark:bg-surface-dark-elevated/50">
    <!-- Traffic light dots -->
    <div class="flex gap-1.5 pl-4 pr-2">
      <span class="h-2.5 w-2.5 rounded-full bg-red-400/60"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-yellow-400/60"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-green-400/60"></span>
    </div>

    <!-- Tab buttons -->
    <div role="tablist" class="flex">
      {tabs.map((tab, i) => (
        <button
          role="tab"
          data-tab-btn
          data-tab-index={String(i)}
          id={`tab-${groupId}-${i}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${groupId}-${i}`}
          class:list={[
            'px-4 py-2.5 text-xs font-medium border-b-2 transition-colors cursor-pointer',
            i === 0
              ? 'text-bipbip-red dark:text-bipbip-yellow border-bipbip-red dark:border-bipbip-yellow'
              : 'text-neutral-400 dark:text-neutral-500 border-transparent hover:text-neutral-600 dark:hover:text-neutral-400',
          ]}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Copy button -->
    <button
      data-tab-copy
      type="button"
      aria-label="Copy code"
      class="ml-auto mr-3 flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-surface-dark-elevated transition-colors"
    >
      <svg class="h-3.5 w-3.5 copy-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
      </svg>
      <svg class="h-3.5 w-3.5 check-icon hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
      <span class="copy-text">Copy</span>
    </button>
  </div>

  <!-- Tab panels -->
  {tabs.map((tab, i) => (
    <div
      role="tabpanel"
      data-tab-panel
      data-tab-index={String(i)}
      id={`panel-${groupId}-${i}`}
      aria-labelledby={`tab-${groupId}-${i}`}
      hidden={i !== 0 ? true : undefined}
    >
      <pre class="overflow-x-auto p-5 text-[13px] leading-relaxed font-mono text-neutral-700 dark:text-neutral-300" set:html={tab.code} />
    </div>
  ))}
</div>

<script is:inline>
  document.querySelectorAll('[data-tabbed-group]').forEach((group) => {
    if (group.hasAttribute('data-initialized')) return;
    group.setAttribute('data-initialized', '');

    const buttons = group.querySelectorAll('[data-tab-btn]');
    const panels = group.querySelectorAll('[data-tab-panel]');
    const copyBtn = group.querySelector('[data-tab-copy]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const index = btn.getAttribute('data-tab-index');

        buttons.forEach((b) => {
          b.classList.remove('text-bipbip-red', 'dark:text-bipbip-yellow', 'border-bipbip-red', 'dark:border-bipbip-yellow');
          b.classList.add('text-neutral-400', 'dark:text-neutral-500', 'border-transparent');
          b.setAttribute('aria-selected', 'false');
        });
        panels.forEach((p) => p.setAttribute('hidden', ''));

        btn.classList.add('text-bipbip-red', 'dark:text-bipbip-yellow', 'border-bipbip-red', 'dark:border-bipbip-yellow');
        btn.classList.remove('text-neutral-400', 'dark:text-neutral-500', 'border-transparent');
        btn.setAttribute('aria-selected', 'true');
        const panel = group.querySelector('[data-tab-panel][data-tab-index="' + index + '"]');
        if (panel) panel.removeAttribute('hidden');
      });
    });

    // Copy active tab
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const activePanel = group.querySelector('[data-tab-panel]:not([hidden]) pre');
        if (!activePanel) return;

        await navigator.clipboard.writeText(activePanel.textContent || '');

        const copyIcon = copyBtn.querySelector('.copy-icon');
        const checkIcon = copyBtn.querySelector('.check-icon');
        const copyText = copyBtn.querySelector('.copy-text');

        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        if (copyText) copyText.textContent = 'Copied!';

        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          if (copyText) copyText.textContent = 'Copy';
        }, 2000);
      });
    }

    // Keyboard navigation
    const tabList = group.querySelector('[role="tablist"]');
    tabList?.addEventListener('keydown', (e) => {
      const tabs = Array.from(buttons);
      const current = tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true');
      let next = current;

      if (e.key === 'ArrowRight') next = (current + 1) % tabs.length;
      else if (e.key === 'ArrowLeft') next = (current - 1 + tabs.length) % tabs.length;
      else return;

      e.preventDefault();
      tabs[next].click();
      tabs[next].focus();
    });
  });
</script>
