---
import NavLink from './NavLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';
import { LogoAltPrimary, LogoPrimaryDefault } from '../icons';
import { useTranslations } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? 'es';
const url = (path: string) => getRelativeLocaleUrl(locale, path);

// Primary links — always visible on desktop
const primaryLinks = [
  { href: url('/docs'), label: t.nav.guide },
  { href: url('/webhook'), label: t.nav.webhook },
  { href: url('/api'), label: t.nav.restApi },
];

// Secondary links — only on xl+ (avoid crowding on lg)
const secondaryLinks: { href: string; label: string }[] = [];

const allLinks = [...primaryLinks, ...secondaryLinks];
---

<header class="sticky top-0 z-50 w-full border-b border-transparent dark:border-border-dark/50 bg-white/80 dark:bg-surface-dark/80 backdrop-blur-xl">
  <nav class="flex h-16 items-center justify-between gap-3 px-4 sm:px-6 lg:pl-8 lg:pr-12">
    <a href={url('/')} id="logo-link" class="flex items-center gap-2 shrink-0">
      <span id="logo-mark" class="dark:hidden inline-block">
        <LogoAltPrimary width={80} height={32} />
      </span>
      <span id="logo-mark-dark" class="hidden dark:inline-block">
        <LogoPrimaryDefault size={32} />
      </span>
      <span class="hidden sm:inline text-xs font-semibold text-neutral-400 dark:text-neutral-500 border-l border-neutral-300 dark:border-border-dark pl-2 ml-1">Developers</span>
    </a>

    <div class="flex items-center gap-2 sm:gap-3 lg:gap-4">
      <!-- Desktop nav: primary links from lg+, secondary only xl+ -->
      <div class="hidden lg:flex items-center gap-5 xl:gap-6">
        {primaryLinks.map((link) => (
          <NavLink href={link.href}>{link.label}</NavLink>
        ))}
        {secondaryLinks.map((link) => (
          <span class="hidden xl:inline-flex">
            <NavLink href={link.href}>{link.label}</NavLink>
          </span>
        ))}
      </div>

      <!-- Search trigger: visible from md+ -->
      <button
        id="palette-trigger"
        type="button"
        aria-label="Search (Ctrl+K)"
        class="hidden md:flex items-center gap-2 rounded-lg border border-neutral-200 dark:border-border-dark bg-neutral-50 dark:bg-surface-dark-elevated px-3 py-1.5 text-xs text-neutral-400 dark:text-neutral-500 hover:border-neutral-300 dark:hover:border-neutral-600 hover:text-neutral-500 dark:hover:text-neutral-400 transition-colors cursor-pointer"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <span class="hidden lg:inline">{t.nav.searchShort}</span>
        <kbd class="ml-1 rounded border border-neutral-300 dark:border-border-dark bg-neutral-100 dark:bg-surface-dark px-1.5 py-0.5 text-[10px] font-mono">Ctrl K</kbd>
      </button>

      <!-- Mobile-only search icon trigger (< md) -->
      <button
        id="palette-trigger-mobile"
        type="button"
        aria-label="Search"
        class="md:hidden flex items-center justify-center rounded-lg p-2 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-surface-dark-elevated transition-colors"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </button>

      <LanguageToggle />
      <ThemeToggle />

      <!-- Mobile hamburger: visible below lg -->
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        class="lg:hidden flex items-center justify-center rounded-lg p-2 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-surface-dark-elevated transition-colors"
      >
        <svg id="menu-open-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-close-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile/tablet menu: active below lg — slide-down animation -->
  <div
    id="mobile-menu"
    class="lg:hidden border-t border-neutral-200 dark:border-border-dark bg-white/95 dark:bg-surface-dark/95 backdrop-blur-xl overflow-hidden"
    style="max-height: 0; transition: max-height 250ms cubic-bezier(0, 0, 0.2, 1), opacity 200ms ease-out; opacity: 0; pointer-events: none;"
    aria-hidden="true"
  >
    <div class="px-4 sm:px-6 py-4 space-y-1">
      {allLinks.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg px-4 py-2.5 text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-surface-dark-elevated hover:text-neutral-900 dark:hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  // Event listeners must be re-attached after Astro view transitions because
  // the <body> — including Header DOM — is replaced on navigation.
  function initHeader() {
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuOpenIcon = document.getElementById('menu-open-icon');
    const menuCloseIcon = document.getElementById('menu-close-icon');
    const paletteTrigger = document.getElementById('palette-trigger');
    const paletteTriggerMobile = document.getElementById('palette-trigger-mobile');

    function openPalette() {
      const palette = document.getElementById('command-palette');
      const input = document.getElementById('palette-input');
      if (palette) { palette.classList.remove('hidden'); document.body.classList.add('overflow-hidden'); }
      if (input) input.focus();
    }

    if (paletteTrigger && paletteTrigger.dataset.bound !== '1') {
      paletteTrigger.dataset.bound = '1';
      paletteTrigger.addEventListener('click', openPalette);
    }
    if (paletteTriggerMobile && paletteTriggerMobile.dataset.bound !== '1') {
      paletteTriggerMobile.dataset.bound = '1';
      paletteTriggerMobile.addEventListener('click', openPalette);
    }

    if (menuToggle && mobileMenu && menuToggle.dataset.bound !== '1') {
      menuToggle.dataset.bound = '1';
      let menuOpen = false;

      function setMenuOpen(open) {
        menuOpen = open;
        if (open) {
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
          mobileMenu.style.opacity = '1';
          mobileMenu.style.pointerEvents = '';
          mobileMenu.setAttribute('aria-hidden', 'false');
        } else {
          mobileMenu.style.maxHeight = '0';
          mobileMenu.style.opacity = '0';
          mobileMenu.style.pointerEvents = 'none';
          mobileMenu.setAttribute('aria-hidden', 'true');
        }
        if (menuOpenIcon) menuOpenIcon.classList.toggle('hidden', open);
        if (menuCloseIcon) menuCloseIcon.classList.toggle('hidden', !open);
        menuToggle.setAttribute('aria-expanded', String(open));
      }

      menuToggle.addEventListener('click', () => setMenuOpen(!menuOpen));
    }
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);

  // Logo click pulse (Easter egg — respects prefers-reduced-motion)
  function initLogoPulse() {
    const logoLink = document.getElementById('logo-link');
    const logoMark = document.getElementById('logo-mark');
    const logoMarkDark = document.getElementById('logo-mark-dark');
    if (!logoLink || logoLink.dataset.pulseBound === '1') return;
    logoLink.dataset.pulseBound = '1';

    logoLink.addEventListener('click', function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const marks = [logoMark, logoMarkDark].filter(Boolean);
      marks.forEach(function(el) {
        el.classList.remove('logo-pulse-active');
        void el.offsetWidth; // force reflow to restart animation
        el.classList.add('logo-pulse-active');
        setTimeout(function() { el.classList.remove('logo-pulse-active'); }, 320);
      });
    });
  }

  initLogoPulse();
  document.addEventListener('astro:page-load', initLogoPulse);

  // Close mobile menu on route change — document listener registered ONCE.
  if (!document.__headerNavBound) {
    document.__headerNavBound = true;
    document.addEventListener('astro:before-preparation', () => {
      const mobileMenu = document.getElementById('mobile-menu');
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const menuOpenIcon = document.getElementById('menu-open-icon');
      const menuCloseIcon = document.getElementById('menu-close-icon');
      if (mobileMenu) {
        mobileMenu.style.maxHeight = '0';
        mobileMenu.style.opacity = '0';
        mobileMenu.style.pointerEvents = 'none';
        mobileMenu.setAttribute('aria-hidden', 'true');
      }
      if (menuOpenIcon) menuOpenIcon.classList.remove('hidden');
      if (menuCloseIcon) menuCloseIcon.classList.add('hidden');
      if (menuToggle) menuToggle.setAttribute('aria-expanded', 'false');
    });
  }
</script>
