---
interface Props {
  href: string;
  class?: string;
}

const { href, class: className, ...attrs } = Astro.props;
const isActive = Astro.url.pathname.startsWith(href);
---

<a
  href={href}
  class:list={[
    'text-sm font-medium transition-colors duration-150',
    isActive
      ? 'text-bipbip-red'
      : 'text-neutral-600 dark:text-neutral-400 hover:text-bipbip-red dark:hover:text-bipbip-red',
    className,
  ]}
  {...attrs}
>
  <slot />
</a>
