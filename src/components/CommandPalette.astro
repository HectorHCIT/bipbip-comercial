---
import { useTranslations } from '../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

const t = useTranslations(Astro.currentLocale);
const uiSearch = t.search;
const locale = Astro.currentLocale ?? 'es';
// Prefix added to all search result URLs: '' for ES (default), '/en' for EN.
const localePrefix = getRelativeLocaleUrl(locale, '/').replace(/\/$/, '');
---

<div
  id="command-palette"
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Command palette"
>
  <div id="palette-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <div class="relative mx-auto mt-[15vh] w-full max-w-lg rounded-xl border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-raised shadow-2xl overflow-hidden">
    <div class="flex items-center gap-3 border-b border-neutral-200 dark:border-border-dark px-4">
      <svg class="h-5 w-5 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <input
        id="palette-input"
        class="w-full bg-transparent py-3.5 text-sm outline-none placeholder-neutral-400 text-neutral-900 dark:text-white"
        type="text"
        placeholder={uiSearch.placeholder}
        role="combobox"
        aria-expanded="true"
        aria-controls="palette-results"
        aria-autocomplete="list"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="hidden sm:inline-flex text-[10px] font-mono border rounded px-1.5 py-0.5 text-neutral-400 border-neutral-300 dark:border-border-dark">ESC</kbd>
    </div>

    <div id="palette-results" class="max-h-[320px] overflow-y-auto overscroll-contain" role="listbox" aria-label="Search results"></div>

    <div class="flex items-center gap-4 border-t border-neutral-200 dark:border-border-dark px-4 py-2.5 text-[11px] text-neutral-400">
      <span>{uiSearch.shortcutNavigate}</span>
      <span>{uiSearch.shortcutOpen}</span>
      <span>{uiSearch.shortcutClose}</span>
    </div>
  </div>
</div>

<script is:inline define:vars={{ uiSearch, localePrefix }}>
(function () {
  var GROUP_LABELS = {
    page: uiSearch.groupPages,
    docs: uiSearch.groupDocs,
    endpoint: uiSearch.groupEndpoints,
    changelog: uiSearch.groupChangelog,
  };
  var EMPTY_STATE_LABEL = uiSearch.emptyState;

  const SEARCH_INDEX = [
    { type: "page", title: "Home", url: "/", keywords: "home landing bipbip merchant" },
    { type: "page", title: "Guía de integración", url: "/docs", keywords: "docs guia quickstart integration" },
    { type: "page", title: "Webhook Spec", url: "/webhook", keywords: "webhook outbound order.created order.cancelled" },
    { type: "page", title: "REST API Reference", url: "/api", keywords: "api rest endpoints reference" },
    { type: "docs", title: "Quickstart", url: "/docs#quickstart", keywords: "primeros pasos quickstart intro" },
    { type: "docs", title: "Precondiciones", url: "/docs#preconditions", keywords: "hmac secret api key remoteid base url onboarding" },
    { type: "docs", title: "Los 4 pasos", url: "/docs#steps", keywords: "pasos webhook verify ack accept" },
    { type: "docs", title: "Sandbox", url: "/docs#sandbox", keywords: "sandbox ambiente pruebas produccion" },
    { type: "docs", title: "Verificación HMAC", url: "/docs#hmac", keywords: "hmac sha256 signature firma seguridad" },
    { type: "docs", title: "Algoritmo HMAC", url: "/docs#hmac-algorithm", keywords: "algorithm algoritmo timestamp rawbody sha256" },
    { type: "docs", title: "Errores comunes (footguns)", url: "/docs#footguns", keywords: "footguns errores timing raw body json parse" },
    { type: "docs", title: "Code samples HMAC", url: "/docs#hmac-samples", keywords: "node python csharp php samples" },
    { type: "docs", title: "Firma no verifica", url: "/docs#faq-firma", keywords: "hmac no verifica troubleshooting signature" },
    { type: "docs", title: "Webhook duplicado", url: "/docs#faq-duplicado", keywords: "duplicado dedupe delivery-id at-least-once" },
    { type: "docs", title: "BipBip sigue reintentando", url: "/docs#faq-reintentos", keywords: "reintentos retry remoteorderid 200" },
    { type: "docs", title: "No recibo webhooks", url: "/docs#faq-nada", keywords: "firewall url publica ngrok" },
    { type: "docs", title: "Glosario", url: "/docs#glossary", keywords: "glosario orderkey remoteorderid remoteid idempotency delivery-id estados" },
    { type: "endpoint", title: "POST /v1/order/:remoteId", url: "/webhook#post-v1-order-remoteid", keywords: "order created webhook receive raw body", method: "POST" },
    { type: "endpoint", title: "POST /v1/order/:remoteId/:remoteOrderId", url: "/webhook#post-v1-order-remoteid-remoteorderid", keywords: "cancellation cancel webhook", method: "POST" },
    { type: "endpoint", title: "POST /api/v1/orders/:orderKey/accept", url: "/api#post-api-v1-orders-orderkey-accept", keywords: "accept orden aceptar", method: "POST" },
    { type: "endpoint", title: "POST /api/v1/orders/:orderKey/reject", url: "/api#post-api-v1-orders-orderkey-reject", keywords: "reject rechazar out of stock", method: "POST" },
    { type: "endpoint", title: "POST /api/v1/orders/:orderKey/status", url: "/api#post-api-v1-orders-orderkey-status", keywords: "status preparing ready transicion estado", method: "POST" },
    { type: "endpoint", title: "GET /api/v1/Orders/:orderKey", url: "/api#get-api-v1-orders-orderkey", keywords: "get orden consulta reconciliar", method: "GET" },
    { type: "endpoint", title: "GET /api/v1/Orders", url: "/api#get-api-v1-orders", keywords: "listar ordenes cursor paginacion", method: "GET" },
  ];

  var GROUP_ORDER = ["page", "docs", "endpoint"];

  var METHOD_COLORS = {
    GET: "bg-green-500/10 text-green-600 dark:text-green-400",
    POST: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
    PUT: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
    DELETE: "bg-red-500/10 text-red-600 dark:text-red-400",
  };

  var ICONS = {
    page: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>',
    docs: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>',
    endpoint: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>',
    changelog: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>',
  };

  // DOM refs are looked up lazily on each call — after a view transition
  // the #command-palette element is replaced so stored refs go stale.
  function getEl(id) { return document.getElementById(id); }
  function getPalette()  { return getEl("command-palette"); }
  function getBackdrop() { return getEl("palette-backdrop"); }
  function getInput()    { return getEl("palette-input"); }
  function getResults()  { return getEl("palette-results"); }

  var activeIndex = -1;
  var currentItems = [];

  function open() {
    var palette = getPalette(); var input = getInput();
    if (!palette) return;
    palette.classList.remove("hidden");
    if (input) input.focus();
    document.body.classList.add("overflow-hidden");
    render("");
  }

  function close() {
    var palette = getPalette(); var input = getInput(); var results = getResults();
    if (palette) palette.classList.add("hidden");
    if (input) input.value = "";
    if (results) results.innerHTML = "";
    activeIndex = -1;
    currentItems = [];
    document.body.classList.remove("overflow-hidden");
  }

  function filter(query) {
    if (!query) return SEARCH_INDEX;
    var q = query.toLowerCase();
    return SEARCH_INDEX.filter(function (item) {
      return item.title.toLowerCase().indexOf(q) !== -1 || item.keywords.indexOf(q) !== -1;
    });
  }

  function groupItems(items) {
    var groups = {};
    for (var i = 0; i < GROUP_ORDER.length; i++) {
      groups[GROUP_ORDER[i]] = [];
    }
    for (var j = 0; j < items.length; j++) {
      var t = items[j].type;
      if (groups[t]) groups[t].push(items[j]);
    }
    return groups;
  }

  function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function render(query) {
    var results = getResults();
    if (!results) return;
    var items = filter(query);
    currentItems = items;
    activeIndex = -1;

    if (items.length === 0) {
      results.innerHTML = '<div class="px-6 py-12 text-center"><p class="text-sm text-neutral-400">' + EMPTY_STATE_LABEL + ' "<strong>' + escapeHtml(query) + '</strong>"</p></div>';
      return;
    }

    var groups = groupItems(items);
    var html = "";
    var globalIdx = 0;

    for (var g = 0; g < GROUP_ORDER.length; g++) {
      var key = GROUP_ORDER[g];
      var group = groups[key];
      if (group.length === 0) continue;

      html += '<div class="px-3 pt-3 pb-1.5"><span class="text-[11px] font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">' + GROUP_LABELS[key] + "</span></div>";

      for (var i = 0; i < group.length; i++) {
        var item = group[i];
        var extra = "";

        if (item.type === "endpoint" && item.method) {
          var color = METHOD_COLORS[item.method] || "";
          extra = '<span class="inline-flex min-w-[2.5rem] justify-center rounded px-1 py-0.5 text-[9px] font-bold font-mono ' + color + '">' + item.method + "</span>";
        }

        // Localize the URL: item.url is locale-agnostic ("/docs"), we prepend the current locale prefix ("" for ES, "/en" for EN).
        // For hash-only URLs or external, keep as-is.
        var localizedUrl = item.url.startsWith('/') ? (localePrefix + item.url) : item.url;
        html += '<a href="' + escapeHtml(localizedUrl) + '" data-palette-item data-index="' + globalIdx + '" role="option" aria-selected="false" class="flex items-center gap-3 mx-2 px-3 py-2 rounded-lg text-sm cursor-pointer text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-surface-dark-elevated transition-colors">';
        html += ICONS[item.type] || "";
        html += extra;
        html += "<span>" + escapeHtml(item.title) + "</span>";
        html += "</a>";

        globalIdx++;
      }
    }

    results.innerHTML = html;
  }

  function updateActive() {
    var results = getResults();
    if (!results) return;
    var allItems = results.querySelectorAll("[data-palette-item]");
    for (var i = 0; i < allItems.length; i++) {
      var el = allItems[i];
      if (i === activeIndex) {
        el.classList.add("bg-neutral-100", "dark:bg-surface-dark-elevated");
        el.setAttribute("aria-selected", "true");
        el.scrollIntoView({ block: "nearest" });
      } else {
        el.classList.remove("bg-neutral-100", "dark:bg-surface-dark-elevated");
        el.setAttribute("aria-selected", "false");
      }
    }
  }

  // Document-level keydown — registered ONCE (document persists across navigations)
  if (!document.__paletteKeydownBound) {
    document.__paletteKeydownBound = true;
    document.addEventListener("keydown", function (e) {
      var palette = getPalette();
      if (!palette) return;

      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (palette.classList.contains("hidden")) open();
        else close();
        return;
      }

      if (palette.classList.contains("hidden")) return;

      var results = getResults();
      if (!results) return;
      var total = results.querySelectorAll("[data-palette-item]").length;

      if (e.key === "Escape") {
        e.preventDefault();
        close();
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (total === 0) return;
        activeIndex = activeIndex < total - 1 ? activeIndex + 1 : 0;
        updateActive();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (total === 0) return;
        activeIndex = activeIndex > 0 ? activeIndex - 1 : total - 1;
        updateActive();
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (activeIndex >= 0) {
          var active = results.querySelector('[data-index="' + activeIndex + '"]');
          if (active) window.location.href = active.getAttribute("href");
        }
      }
    });
  }

  // Element-level listeners — re-attach on every page load because the palette
  // DOM node is replaced during Astro view transitions.
  function bindElementListeners() {
    var palette = getPalette();
    var backdrop = getBackdrop();
    var input = getInput();
    if (!palette || palette.dataset.bound === '1') return;
    palette.dataset.bound = '1';

    if (backdrop) backdrop.addEventListener("click", close);
    if (input) input.addEventListener("input", function () { render(input.value.trim()); });
  }

  bindElementListeners();
  document.addEventListener('astro:page-load', bindElementListeners);
})();
</script>
