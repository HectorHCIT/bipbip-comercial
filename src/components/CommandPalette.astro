---
---

<div
  id="command-palette"
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Command palette"
>
  <div id="palette-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <div class="relative mx-auto mt-[15vh] w-full max-w-lg rounded-xl border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-raised shadow-2xl overflow-hidden">
    <div class="flex items-center gap-3 border-b border-neutral-200 dark:border-border-dark px-4">
      <svg class="h-5 w-5 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <input
        id="palette-input"
        class="w-full bg-transparent py-3.5 text-sm outline-none placeholder-neutral-400 text-neutral-900 dark:text-white"
        type="text"
        placeholder="Search pages, docs, endpoints..."
        role="combobox"
        aria-expanded="true"
        aria-controls="palette-results"
        aria-autocomplete="list"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="hidden sm:inline-flex text-[10px] font-mono border rounded px-1.5 py-0.5 text-neutral-400 border-neutral-300 dark:border-border-dark">ESC</kbd>
    </div>

    <div id="palette-results" class="max-h-[320px] overflow-y-auto overscroll-contain" role="listbox" aria-label="Search results"></div>

    <div class="flex items-center gap-4 border-t border-neutral-200 dark:border-border-dark px-4 py-2.5 text-[11px] text-neutral-400">
      <span>&#8593;&#8595; Navigate</span>
      <span>&#8629; Open</span>
      <span>esc Close</span>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  const SEARCH_INDEX = [
    { type: "page", title: "Home", url: "/", keywords: "home landing bipbip" },
    { type: "page", title: "Documentation", url: "/docs", keywords: "docs getting started guide" },
    { type: "page", title: "API Reference", url: "/api", keywords: "api endpoints reference" },
    { type: "page", title: "Changelog", url: "/changelog", keywords: "changelog updates versions releases" },
    { type: "page", title: "Status", url: "/status", keywords: "status uptime health operational" },
    { type: "docs", title: "Authentication", url: "/docs#authentication", keywords: "auth bearer token api key" },
    { type: "docs", title: "First Request", url: "/docs#first-request", keywords: "quickstart curl example tutorial" },
    { type: "docs", title: "Environments", url: "/docs#environments", keywords: "sandbox production base url" },
    { type: "docs", title: "Rate Limits", url: "/docs#rate-limits", keywords: "throttle 429 limit" },
    { type: "endpoint", title: "GET /v1/orders", url: "/api#get-v1-orders", keywords: "list orders paginated", method: "GET" },
    { type: "endpoint", title: "POST /v1/orders", url: "/api#post-v1-orders", keywords: "create order delivery", method: "POST" },
    { type: "endpoint", title: "GET /v1/orders/:id", url: "/api#get-v1-orders-id", keywords: "retrieve order detail", method: "GET" },
    { type: "endpoint", title: "PUT /v1/orders/:id/cancel", url: "/api#put-v1-orders-id-cancel", keywords: "cancel order", method: "PUT" },
    { type: "endpoint", title: "GET /v1/restaurants", url: "/api#get-v1-restaurants", keywords: "list restaurants browse", method: "GET" },
    { type: "endpoint", title: "GET /v1/restaurants/:id", url: "/api#get-v1-restaurants-id", keywords: "restaurant detail info", method: "GET" },
    { type: "endpoint", title: "GET /v1/restaurants/:id/menu", url: "/api#get-v1-restaurants-id-menu", keywords: "menu items categories food", method: "GET" },
    { type: "endpoint", title: "GET /v1/drivers/:id", url: "/api#get-v1-drivers-id", keywords: "driver profile info", method: "GET" },
    { type: "endpoint", title: "GET /v1/drivers/:id/location", url: "/api#get-v1-drivers-id-location", keywords: "driver gps tracking live", method: "GET" },
    { type: "endpoint", title: "POST /v1/webhooks", url: "/api#post-v1-webhooks", keywords: "create webhook subscribe events", method: "POST" },
    { type: "endpoint", title: "GET /v1/webhooks", url: "/api#get-v1-webhooks", keywords: "list webhooks subscriptions", method: "GET" },
    { type: "endpoint", title: "DELETE /v1/webhooks/:id", url: "/api#delete-v1-webhooks-id", keywords: "remove webhook unsubscribe", method: "DELETE" },
    { type: "changelog", title: "v1.2.0 \u2014 Real-time tracking", url: "/changelog", keywords: "websocket batch driver tracking" },
    { type: "changelog", title: "v1.1.0 \u2014 Webhook management", url: "/changelog", keywords: "webhook menu fixes" },
    { type: "changelog", title: "v1.0.0 \u2014 Initial release", url: "/changelog", keywords: "launch first version orders restaurants" },
  ];

  var GROUP_ORDER = ["page", "docs", "endpoint", "changelog"];
  var GROUP_LABELS = { page: "Pages", docs: "Documentation", endpoint: "API Endpoints", changelog: "Changelog" };

  var METHOD_COLORS = {
    GET: "bg-green-500/10 text-green-600 dark:text-green-400",
    POST: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
    PUT: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
    DELETE: "bg-red-500/10 text-red-600 dark:text-red-400",
  };

  var ICONS = {
    page: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>',
    docs: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>',
    endpoint: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>',
    changelog: '<svg class="h-4 w-4 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>',
  };

  var palette = document.getElementById("command-palette");
  var backdrop = document.getElementById("palette-backdrop");
  var input = document.getElementById("palette-input");
  var results = document.getElementById("palette-results");
  var activeIndex = -1;
  var currentItems = [];

  function open() {
    palette.classList.remove("hidden");
    input.focus();
    document.body.classList.add("overflow-hidden");
    render("");
  }

  function close() {
    palette.classList.add("hidden");
    input.value = "";
    results.innerHTML = "";
    activeIndex = -1;
    currentItems = [];
    document.body.classList.remove("overflow-hidden");
  }

  function filter(query) {
    if (!query) return SEARCH_INDEX;
    var q = query.toLowerCase();
    return SEARCH_INDEX.filter(function (item) {
      return item.title.toLowerCase().indexOf(q) !== -1 || item.keywords.indexOf(q) !== -1;
    });
  }

  function groupItems(items) {
    var groups = {};
    for (var i = 0; i < GROUP_ORDER.length; i++) {
      groups[GROUP_ORDER[i]] = [];
    }
    for (var j = 0; j < items.length; j++) {
      var t = items[j].type;
      if (groups[t]) groups[t].push(items[j]);
    }
    return groups;
  }

  function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function render(query) {
    var items = filter(query);
    currentItems = items;
    activeIndex = -1;

    if (items.length === 0) {
      results.innerHTML = '<div class="px-6 py-12 text-center"><p class="text-sm text-neutral-400">No results for "<strong>' + escapeHtml(query) + '</strong>"</p></div>';
      return;
    }

    var groups = groupItems(items);
    var html = "";
    var globalIdx = 0;

    for (var g = 0; g < GROUP_ORDER.length; g++) {
      var key = GROUP_ORDER[g];
      var group = groups[key];
      if (group.length === 0) continue;

      html += '<div class="px-3 pt-3 pb-1.5"><span class="text-[11px] font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">' + GROUP_LABELS[key] + "</span></div>";

      for (var i = 0; i < group.length; i++) {
        var item = group[i];
        var extra = "";

        if (item.type === "endpoint" && item.method) {
          var color = METHOD_COLORS[item.method] || "";
          extra = '<span class="inline-flex min-w-[2.5rem] justify-center rounded px-1 py-0.5 text-[9px] font-bold font-mono ' + color + '">' + item.method + "</span>";
        }

        html += '<a href="' + escapeHtml(item.url) + '" data-palette-item data-index="' + globalIdx + '" role="option" aria-selected="false" class="flex items-center gap-3 mx-2 px-3 py-2 rounded-lg text-sm cursor-pointer text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-surface-dark-elevated transition-colors">';
        html += ICONS[item.type] || "";
        html += extra;
        html += "<span>" + escapeHtml(item.title) + "</span>";
        html += "</a>";

        globalIdx++;
      }
    }

    results.innerHTML = html;
  }

  function updateActive() {
    var allItems = results.querySelectorAll("[data-palette-item]");
    for (var i = 0; i < allItems.length; i++) {
      var el = allItems[i];
      if (i === activeIndex) {
        el.classList.add("bg-neutral-100", "dark:bg-surface-dark-elevated");
        el.setAttribute("aria-selected", "true");
        el.scrollIntoView({ block: "nearest" });
      } else {
        el.classList.remove("bg-neutral-100", "dark:bg-surface-dark-elevated");
        el.setAttribute("aria-selected", "false");
      }
    }
  }

  document.addEventListener("keydown", function (e) {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      if (palette.classList.contains("hidden")) {
        open();
      } else {
        close();
      }
      return;
    }

    if (palette.classList.contains("hidden")) return;

    var total = results.querySelectorAll("[data-palette-item]").length;

    if (e.key === "Escape") {
      e.preventDefault();
      close();
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      if (total === 0) return;
      activeIndex = activeIndex < total - 1 ? activeIndex + 1 : 0;
      updateActive();
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      if (total === 0) return;
      activeIndex = activeIndex > 0 ? activeIndex - 1 : total - 1;
      updateActive();
    } else if (e.key === "Enter") {
      e.preventDefault();
      if (activeIndex >= 0) {
        var active = results.querySelector('[data-index="' + activeIndex + '"]');
        if (active) window.location.href = active.getAttribute("href");
      }
    }
  });

  backdrop.addEventListener("click", close);

  input.addEventListener("input", function () {
    render(input.value.trim());
  });
})();
</script>
