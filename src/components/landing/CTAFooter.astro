---
import { LogoPrimaryDefault } from '../icons';
---

<section class="relative overflow-hidden bg-gradient-to-br from-bipbip-red to-bipbip-red-dark py-24">
  <!-- Subtle radial patterns -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.05),transparent_50%)]"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,rgba(253,195,0,0.08),transparent_50%)]"></div>

  <!-- Brand pattern — full width background -->
  <img
    src="/iconografia/Patron.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 w-full h-full object-cover opacity-[0.06]"
    style="animation: logo-pulse 6s ease-in-out infinite"
  />

  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <!-- Logo -->
    <div class="mx-auto mb-8">
      <LogoPrimaryDefault size={56} class="mx-auto drop-shadow-lg" />
    </div>

    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Ready to build with BipBip?
    </h2>
    <p class="mt-4 text-lg text-white/80">
      Join developers building the future of food delivery in Honduras.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/docs"
        class="shimmer-btn relative rounded-lg bg-white px-6 py-3 text-sm font-semibold text-bipbip-red shadow-lg transition-all duration-200 hover:bg-neutral-100 hover:-translate-y-0.5 overflow-hidden"
      >
        <span class="relative z-10">Start Building</span>
      </a>
      <a
        href="https://bipbip.hn"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:border-white/60 hover:-translate-y-0.5"
      >
        Contact Sales
      </a>
    </div>
  </div>
</section>

<style>
  .shimmer-btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(227, 6, 19, 0.08),
      rgba(227, 6, 19, 0.15),
      rgba(227, 6, 19, 0.08),
      transparent
    );
    animation: shimmer 3s ease-in-out infinite;
    animation-delay: 1s;
  }

  @keyframes shimmer {
    0% { left: -100%; }
    50% { left: 150%; }
    100% { left: 150%; }
  }
</style>
