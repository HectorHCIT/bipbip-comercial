---
import { AppIcon } from '../icons';
import { useTranslations } from '../../i18n/ui';

const t = useTranslations(Astro.currentLocale);
const gs = t.gettingStarted;
---

<section class="relative mx-auto max-w-6xl px-6 py-24 overflow-hidden" data-animate>
  <!-- Background illustration: delivery — signature moment -->
  <img
    src="/iconografia/renderizado-3d-icono-entrega 1.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -left-12 top-1/2 -translate-y-1/2 w-96 h-96 opacity-[0.15] dark:opacity-[0.10] -rotate-12 select-none"
  />

  <div class="relative">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">
        {gs.title}
      </h2>
      <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
        {gs.subtitle}
      </p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {gs.steps.map((step, i) => (
        <div class="text-center" data-animate style={`transition-delay: ${i * 80}ms`}>
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-bipbip-red to-bipbip-orange text-lg font-bold text-white shadow-lg shadow-bipbip-red/20">
            {i + 1}
          </div>
          <h3 class="mt-5 text-base font-semibold text-neutral-900 dark:text-white">
            {step.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            {step.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- Precondiciones callout -->
    <div class="mt-16 mx-auto max-w-3xl rounded-2xl border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-raised p-6">
      <div class="flex items-center gap-3">
        <AppIcon width={40} height={40} class="rounded-lg" />
        <div>
          <p class="text-sm font-semibold text-neutral-900 dark:text-white">{gs.calloutTitle}</p>
          <p class="text-xs text-neutral-500 dark:text-neutral-400">{gs.calloutSubtitle}</p>
        </div>
      </div>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2 text-sm text-neutral-600 dark:text-neutral-400">
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-bipbip-red" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          {gs.prereqHmac}
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-bipbip-red" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <span set:html={gs.prereqApiKey} />
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-bipbip-red" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          {gs.prereqRemoteId}
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-bipbip-red" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          {gs.prereqBaseUrl}
        </li>
      </ul>
    </div>
  </div>
</section>
