---
import FeatureCard from './FeatureCard.astro';
---

<section class="relative mx-auto max-w-6xl px-6 py-24 overflow-hidden" data-animate>
  <!-- Background illustration: bag -->
  <img
    src="/iconografia/Bolsa de papel 1-1.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -right-10 -top-10 w-80 h-80 opacity-[0.10] dark:opacity-[0.06] rotate-12"
  />

  <div class="relative">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">
        Everything you need to integrate
      </h2>
      <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
        A complete set of APIs to power your food delivery integration.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <FeatureCard title="Orders API" description="Create, track, and manage delivery orders programmatically with full lifecycle control.">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
        </svg>
      </FeatureCard>

      <FeatureCard title="Restaurants" description="Access menus, availability, hours, and store management for your integrations.">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0021 9.349m-18 0V4.125C3 3.504 3.504 3 4.125 3h15.75C20.496 3 21 3.504 21 4.125V9.35" />
        </svg>
      </FeatureCard>

      <FeatureCard title="Drivers" description="Assign drivers, track real-time location, and manage your delivery fleet efficiently.">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21m-3 0h-1.875a1.125 1.125 0 01-1.125-1.125V14.25m0 0V5.625A1.125 1.125 0 0116.125 4.5h-1.247a.75.75 0 00-.532.22l-4.608 4.608a.75.75 0 00-.22.532V14.25m7.5 0H3.375" />
        </svg>
      </FeatureCard>

      <FeatureCard title="Real-time Tracking" description="Live order tracking with WebSocket updates for seamless delivery experiences.">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
      </FeatureCard>

      <FeatureCard title="Webhooks" description="Get notified instantly of order status changes, driver updates, and more events.">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
        </svg>
      </FeatureCard>

      <FeatureCard title="Authentication" description="OAuth 2.0 with scoped API keys for secure and granular access control.">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </FeatureCard>
    </div>
  </div>
</section>
