---
import FeatureCard from './FeatureCard.astro';
import { useTranslations } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

const t = useTranslations(Astro.currentLocale);
const f = t.features;
const locale = Astro.currentLocale ?? 'es';
const url = (path: string) => getRelativeLocaleUrl(locale, path);
---

<section class="relative mx-auto max-w-6xl px-6 py-24 overflow-hidden" data-animate>
  <!-- Background illustration: bag -->
  <img
    src="/iconografia/Bolsa de papel 1-1.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -right-10 -top-10 w-80 h-80 opacity-[0.10] dark:opacity-[0.06] rotate-12"
  />

  <div class="relative">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">
        {f.sectionTitle}
      </h2>
      <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
        {f.sectionSubtitle}
      </p>
    </div>

    <!-- 3 resource cards -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <a
        href={url('/webhook')}
        data-animate
        style="transition-delay: 80ms"
        class="group relative flex flex-col rounded-2xl border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-raised p-6 transition-all duration-200 hover:border-bipbip-red/40 hover:-translate-y-1 hover:shadow-xl hover:shadow-bipbip-red/10"
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-bipbip-red/10 text-bipbip-red dark:bg-bipbip-red/15">
          <svg class="h-6 w-6 transition-transform duration-300 group-hover:rotate-6" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12" />
            <path d="M6 9l6 6 6-6" />
            <path d="M4 20h16" />
          </svg>
        </div>
        <span class="mb-2 inline-flex w-fit items-center rounded-full border border-bipbip-red/20 bg-bipbip-red/5 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-bipbip-red">
          {f.webhookBadge}
        </span>
        <h3 class="text-lg font-semibold text-neutral-900 dark:text-white">{f.webhookTitle}</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400" set:html={f.webhookDesc} />
        <span class="mt-auto pt-4 text-sm font-semibold text-bipbip-red group-hover:text-bipbip-red-dark">
          {f.webhookCta}
        </span>
      </a>

      <a
        href={url('/api')}
        data-animate
        style="transition-delay: 140ms"
        class="group relative flex flex-col rounded-2xl border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-raised p-6 transition-all duration-200 hover:border-bipbip-yellow/60 hover:-translate-y-1 hover:shadow-xl hover:shadow-bipbip-yellow/10"
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-bipbip-yellow/15 text-bipbip-yellow-dark dark:text-bipbip-yellow">
          <svg class="h-6 w-6 transition-transform duration-300 group-hover:rotate-6" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 3l4 4-4 4" />
            <path d="M3 7h18" />
            <path d="M7 21l-4-4 4-4" />
            <path d="M21 17H3" />
          </svg>
        </div>
        <span class="mb-2 inline-flex w-fit items-center rounded-full border border-bipbip-yellow/40 bg-bipbip-yellow/10 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-bipbip-yellow-dark dark:text-bipbip-yellow">
          {f.restApiBadge}
        </span>
        <h3 class="text-lg font-semibold text-neutral-900 dark:text-white">{f.restApiTitle}</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400" set:html={f.restApiDesc} />
        <span class="mt-auto pt-4 text-sm font-semibold text-bipbip-yellow-dark group-hover:text-bipbip-red dark:text-bipbip-yellow">
          {f.restApiCta}
        </span>
      </a>

      <a
        href={url('/docs')}
        data-animate
        style="transition-delay: 200ms"
        class="group relative flex flex-col rounded-2xl border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-raised p-6 transition-all duration-200 hover:border-bipbip-orange/50 hover:-translate-y-1 hover:shadow-xl hover:shadow-bipbip-orange/10"
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-bipbip-orange/15 text-bipbip-orange">
          <svg class="h-6 w-6 transition-transform duration-300 group-hover:rotate-6" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <span class="mb-2 inline-flex w-fit items-center rounded-full border border-bipbip-orange/40 bg-bipbip-orange/10 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-bipbip-orange">
          {f.guideBadge}
        </span>
        <h3 class="text-lg font-semibold text-neutral-900 dark:text-white">{f.guideTitle}</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
          {f.guideDesc}
        </p>
        <span class="mt-auto pt-4 text-sm font-semibold text-bipbip-orange group-hover:text-bipbip-red">
          {f.guideCta}
        </span>
      </a>
    </div>

    <!-- Highlight features row -->
    <div class="mt-20 text-center">
      <h3 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
        {f.highlightTitle}
      </h3>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <FeatureCard title={f.hmacTitle} description={f.hmacDesc}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </FeatureCard>

      <FeatureCard title={f.deliveryTitle} description={f.deliveryDesc}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
        </svg>
      </FeatureCard>

      <FeatureCard title={f.idempotencyTitle} description={f.idempotencyDesc}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
        </svg>
      </FeatureCard>

      <FeatureCard title={f.samplesTitle} description={f.samplesDesc}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
        </svg>
      </FeatureCard>

      <FeatureCard title={f.stateMachineTitle} description={f.stateMachineDesc}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
      </FeatureCard>

      <FeatureCard title={f.versioningTitle} description={f.versioningDesc}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
      </FeatureCard>
    </div>
  </div>
</section>
