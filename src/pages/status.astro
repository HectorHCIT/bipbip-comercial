---
import Layout from '../layouts/Layout.astro';
import FloatingIcons from '../components/FloatingIcons.astro';

const services = [
  { name: 'API', ping: '12ms' },
  { name: 'Webhooks', ping: '18ms' },
  { name: 'Dashboard', ping: '24ms' },
  { name: 'Sandbox', ping: '15ms' },
];

const uptimeDays = Array.from({ length: 30 }, (_, i) => {
  if (i === 12) return { status: 'partial', uptime: 99.2, label: 'Partial outage' };
  const up = 99.9 + Math.round((Math.random() * 0.1) * 100) / 100;
  return { status: 'ok', uptime: Math.min(up, 100), label: 'No incidents' };
});
---

<Layout title="System Status - BipBip Developer Portal" description="Current operational status and uptime for BipBip API services.">
  <div class="relative mx-auto max-w-3xl px-6 py-16 overflow-hidden">
    <FloatingIcons density="sparse" />

    <div class="relative">
      <h1 class="text-4xl font-bold tracking-tight text-neutral-900 dark:text-white">System Status</h1>
      <p class="mt-3 text-lg text-neutral-600 dark:text-neutral-400">
        Current operational status for BipBip services.
      </p>

      <!-- Overall status banner with animated check -->
      <div data-animate class="mt-10 rounded-xl border border-green-500/30 bg-green-500/5 p-6 text-center">
        <div class="flex items-center justify-center gap-2">
          <svg class="h-6 w-6 text-green-500 status-check-icon" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <circle cx="12" cy="12" r="9" class="status-check-circle" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75" class="status-check-path" />
          </svg>
          <span class="text-xl font-semibold text-green-600 dark:text-green-400">All Systems Operational</span>
        </div>
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
          Last checked: just now
        </p>
      </div>

      <!-- Service list with staggered entrance + heartbeat dots -->
      <div class="mt-10 space-y-3">
        {services.map((service, i) => (
          <div
            data-animate
            style={'transition-delay: ' + (i * 100 + 200) + 'ms'}
            class="flex items-center justify-between rounded-lg border border-neutral-200 dark:border-border-dark bg-surface-light-raised dark:bg-surface-dark-raised px-5 py-4"
          >
            <div class="flex items-center gap-3">
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 status-heartbeat"
                  style={'animation-delay: ' + (i * 300) + 'ms'}
                ></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"></span>
              </span>
              <span class="font-medium text-neutral-900 dark:text-white">{service.name}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-neutral-400 dark:text-neutral-500">{service.ping}</span>
              <span class="text-sm font-medium text-green-600 dark:text-green-400">Operational</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Uptime chart with bouncing bars + tooltips -->
      <div class="mt-14" data-animate style="transition-delay: 800ms">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">Uptime &mdash; Last 30 Days</h2>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">99.98% average</p>

        <div class="mt-6 flex items-end gap-0.5 h-12" id="uptime-chart">
          {uptimeDays.map((day, i) => (
            <div
              class="uptime-bar-wrapper group relative flex-1 h-full flex items-end"
              data-day={30 - i}
              data-uptime={day.uptime}
              data-label={day.label}
            >
              <div
                class:list={[
                  'uptime-bar w-full rounded-sm transition-all duration-200 cursor-pointer hover:opacity-80',
                  day.status === 'ok'
                    ? 'bg-green-500 dark:bg-green-500'
                    : 'bg-amber-500 dark:bg-amber-500 status-bar-pulse',
                ]}
                style={'height: 0; animation-delay: ' + (i * 40) + 'ms'}
              ></div>
              <!-- Tooltip -->
              <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:block z-10">
                <div class="rounded-lg border border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-elevated px-3 py-2 shadow-lg text-center whitespace-nowrap">
                  <p class="text-xs font-semibold text-neutral-900 dark:text-white">
                    Day {30 - i}
                  </p>
                  <p class:list={[
                    'text-[11px] font-medium',
                    day.status === 'ok' ? 'text-green-600 dark:text-green-400' : 'text-amber-600 dark:text-amber-400'
                  ]}>
                    {day.uptime}% &mdash; {day.label}
                  </p>
                </div>
                <div class="mx-auto h-2 w-2 -mt-1 rotate-45 border-b border-r border-neutral-200 dark:border-border-dark bg-white dark:bg-surface-dark-elevated"></div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-2 flex justify-between text-xs text-neutral-500 dark:text-neutral-400">
          <span>30 days ago</span>
          <span>Today</span>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Heartbeat pulse on green dots */
  .status-heartbeat {
    animation: heartbeat 2s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); opacity: 0; }
    50% { transform: scale(2.5); opacity: 0.4; }
  }

  /* Animated check icon stroke draw */
  .status-check-circle {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
    animation: draw-circle 0.6s ease-out 0.3s forwards;
  }

  .status-check-path {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: draw-check 0.4s ease-out 0.8s forwards;
  }

  @keyframes draw-circle {
    to { stroke-dashoffset: 0; }
  }

  @keyframes draw-check {
    to { stroke-dashoffset: 0; }
  }

  /* Amber bar pulse */
  .status-bar-pulse {
    animation: bar-pulse 2s ease-in-out infinite;
  }

  @keyframes bar-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* Bar bounce-in animation */
  .uptime-bar.animate-in {
    animation: bar-bounce-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes bar-bounce-in {
    0% { height: 0; }
    60% { height: 110%; }
    80% { height: 90%; }
    100% { height: 100%; }
  }

  /* Idle bounce for bars */
  .uptime-bar.idle-bounce {
    animation: bar-idle-bounce var(--bounce-duration, 3s) ease-in-out infinite;
    animation-delay: var(--bounce-delay, 0s);
  }

  @keyframes bar-idle-bounce {
    0%, 100% { height: 100%; }
    50% { height: 70%; }
  }
</style>

<script is:inline>
  // Animate bars: reveal bounce then idle bounce
  const chart = document.getElementById('uptime-chart');
  if (chart) {
    const bars = chart.querySelectorAll('.uptime-bar');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Staggered bounce-in
          bars.forEach((bar, i) => {
            setTimeout(() => {
              bar.classList.add('animate-in');

              // After bounce-in, switch to idle bounce
              bar.addEventListener('animationend', function handler() {
                bar.removeEventListener('animationend', handler);
                bar.classList.remove('animate-in');
                bar.classList.add('idle-bounce');
                bar.style.height = '100%';
                // Stagger the idle bounce so they wave
                bar.style.setProperty('--bounce-duration', (2.5 + Math.random() * 1.5) + 's');
                bar.style.setProperty('--bounce-delay', (i * 0.06) + 's');
              });
            }, i * 40);
          });

          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(chart);
  }
</script>
