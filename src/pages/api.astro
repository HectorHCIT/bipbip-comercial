---
import DocsLayout from '../components/docs/DocsLayout.astro';
import SidebarGroup from '../components/docs/SidebarGroup.astro';
import SidebarLink from '../components/docs/SidebarLink.astro';
import EndpointCard from '../components/docs/EndpointCard.astro';
import Callout from '../components/docs/Callout.astro';

// ── Response bodies reales del swagger ──────────────────────────────────────

