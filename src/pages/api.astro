const listOrdersResponse = `{
  <span class="text-blue-600 dark:text-blue-400">"message"</span>: <span class="text-green-700 dark:text-green-400">"Ok"</span>,
  <span class="text-blue-600 dark:text-blue-400">"data"</span>: {
    <span class="text-blue-600 dark:text-blue-400">"items"</span>: [
      {
        <span class="text-blue-600 dark:text-blue-400">"orderKey"</span>: <span class="text-green-700 dark:text-green-400">"ord_7h3nXpQa2KvLmN9F"</span>,
        <span class="text-blue-600 dark:text-blue-400">"storeId"</span>: <span class="text-amber-600 dark:text-amber-400">42</span>,
