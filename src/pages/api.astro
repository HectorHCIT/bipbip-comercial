const errorResponse = `{
  <span class="text-blue-600 dark:text-blue-400">"type"</span>: <span class="text-green-700 dark:text-green-400">"https://errors.bipbip.com/not-found"</span>,
  <span class="text-blue-600 dark:text-blue-400">"title"</span>: <span class="text-green-700 dark:text-green-400">"Order not found"</span>,
  <span class="text-blue-600 dark:text-blue-400">"detail"</span>: <span class="text-green-700 dark:text-green-400">"The order ord_xxx does not exist or does not belong to the authenticated client."</span>,
  <span class="text-blue-600 dark:text-blue-400">"status"</span>: <span class="text-amber-600 dark:text-amber-400">404</span>,
  <span class="text-blue-600 dark:text-blue-400">"traceId"</span>: <span class="text-green-700 dark:text-green-400">"00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01"</span>,
  <span class="text-blue-600 dark:text-blue-400">"meta"</span>: <span class="text-purple-600 dark:text-purple-400">null</span>
}`;

const validationErrorResponse = `{
  <span class="text-blue-600 dark:text-blue-400">"type"</span>: <span class="text-green-700 dark:text-green-400">"https://errors.bipbip.com/validation"</span>,
