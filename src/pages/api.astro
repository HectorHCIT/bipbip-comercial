---

<DocsLayout title="API Reference">
  <Fragment slot="sidebar">
    <SidebarGroup title="Orders">
      <SidebarLink href="#get-v1-orders" method="GET">/v1/orders</SidebarLink>
      <SidebarLink href="#post-v1-orders" method="POST">/v1/orders</SidebarLink>
      <SidebarLink href="#get-v1-orders-id" method="GET">/v1/orders/:id</SidebarLink>
      <SidebarLink href="#put-v1-orders-id-cancel" method="PUT">/v1/orders/:id/cancel</SidebarLink>
    </SidebarGroup>

    <SidebarGroup title="Restaurants">
      <SidebarLink href="#get-v1-restaurants" method="GET">/v1/restaurants</SidebarLink>
      <SidebarLink href="#get-v1-restaurants-id" method="GET">/v1/restaurants/:id</SidebarLink>
      <SidebarLink href="#get-v1-restaurants-id-menu" method="GET">/v1/restaurants/:id/menu</SidebarLink>
    </SidebarGroup>

    <SidebarGroup title="Drivers">
      <SidebarLink href="#get-v1-drivers-id" method="GET">/v1/drivers/:id</SidebarLink>
      <SidebarLink href="#get-v1-drivers-id-location" method="GET">/v1/drivers/:id/location</SidebarLink>
    </SidebarGroup>

    <SidebarGroup title="Webhooks">
      <SidebarLink href="#post-v1-webhooks" method="POST">/v1/webhooks</SidebarLink>
      <SidebarLink href="#get-v1-webhooks" method="GET">/v1/webhooks</SidebarLink>
      <SidebarLink href="#delete-v1-webhooks-id" method="DELETE">/v1/webhooks/:id</SidebarLink>
    </SidebarGroup>
  </Fragment>

  <!-- Header -->
  <section id="api-reference" class="scroll-mt-24">
    <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">
      API Reference
    </h1>
    <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
      Complete reference for all BipBip API endpoints. Each endpoint includes the
      HTTP method, path, description, and an example response.
    </p>

    <Callout type="info">
      <Fragment slot="title">Base URL</Fragment>
      All endpoints are relative to
      <code class="rounded bg-blue-100 dark:bg-blue-500/10 px-1 py-0.5 text-xs font-mono">https://api.bipbip.hn/v1</code>
    </Callout>
  </section>

  <hr class="my-12 border-neutral-200 dark:border-border-dark" />

  <!-- Orders -->
  <section id="orders" class="scroll-mt-24">
    <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
      Orders
    </h2>
    <p class="mt-4 text-neutral-600 dark:text-neutral-400">
      Create, retrieve, list, and cancel delivery orders. Orders represent a
      customer purchase from a restaurant, assigned to a driver for delivery.
    </p>

    <div class="mt-6 space-y-4">
      <EndpointCard
        method="GET"
        path="/v1/orders"
        description="List all orders with optional filters for status, date range, and restaurant. Returns a paginated list sorted by creation date."
        responseCode={listOrdersResponse}
      />

      <EndpointCard
        method="POST"
        path="/v1/orders"
        description="Create a new delivery order. Requires a restaurant ID, delivery address, and at least one item. Returns the created order with a pending status."
        responseCode={createOrderResponse}
      />

      <EndpointCard
        method="GET"
        path="/v1/orders/:id"
        description="Retrieve a single order by its unique ID. Includes full order details, current status, assigned driver, and delivery estimates."
        responseCode={getOrderResponse}
      />

      <EndpointCard
        method="PUT"
        path="/v1/orders/:id/cancel"
        description="Cancel an active order. Only orders with status pending or accepted can be cancelled. Requires a cancellation reason."
        responseCode={cancelOrderResponse}
      />
    </div>
  </section>

  <hr class="my-12 border-neutral-200 dark:border-border-dark" />

  <!-- Restaurants -->
  <section id="restaurants" class="scroll-mt-24">
    <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
      Restaurants
    </h2>
    <p class="mt-4 text-neutral-600 dark:text-neutral-400">
      Browse restaurants, retrieve details, and access menus. Restaurants are the
      merchant partners on the BipBip platform.
    </p>

    <div class="mt-6 space-y-4">
      <EndpointCard
        method="GET"
        path="/v1/restaurants"
        description="List all restaurants with optional filters for city, active status, and cuisine type. Returns a paginated list."
        responseCode={listRestaurantsResponse}
      />

      <EndpointCard
        method="GET"
        path="/v1/restaurants/:id"
        description="Retrieve detailed information about a restaurant including address, operating hours, rating, and active status."
        responseCode={getRestaurantResponse}
      />

      <EndpointCard
        method="GET"
        path="/v1/restaurants/:id/menu"
        description="Retrieve the full menu for a restaurant, organized by categories with item details and pricing."
        responseCode={getMenuResponse}
      />
    </div>
  </section>

  <hr class="my-12 border-neutral-200 dark:border-border-dark" />

  <!-- Drivers -->
  <section id="drivers" class="scroll-mt-24">
    <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
      Drivers
    </h2>
    <p class="mt-4 text-neutral-600 dark:text-neutral-400">
      Access driver profiles and real-time location data. Drivers are the delivery
      partners who pick up and deliver orders.
    </p>

    <div class="mt-6 space-y-4">
      <EndpointCard
        method="GET"
        path="/v1/drivers/:id"
        description="Retrieve a driver's profile including name, vehicle type, current status, and rating."
        responseCode={getDriverResponse}
      />

      <EndpointCard
        method="GET"
        path="/v1/drivers/:id/location"
        description="Get the real-time GPS location of a driver. Returns latitude, longitude, heading, and last update timestamp."
        responseCode={getDriverLocationResponse}
      />
    </div>
  </section>

  <hr class="my-12 border-neutral-200 dark:border-border-dark" />

  <!-- Webhooks -->
  <section id="webhooks" class="scroll-mt-24">
    <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
      Webhooks
    </h2>
    <p class="mt-4 text-neutral-600 dark:text-neutral-400">
      Subscribe to real-time event notifications. Webhooks push updates to your
      server when order statuses change, deliveries complete, and more.
    </p>

    <div class="mt-6 space-y-4">
      <EndpointCard
        method="POST"
        path="/v1/webhooks"
        description="Register a new webhook endpoint. Provide a URL and a list of event types to subscribe to."
        responseCode={createWebhookResponse}
      />

      <EndpointCard
        method="GET"
        path="/v1/webhooks"
        description="List all registered webhook endpoints for your account, including their event subscriptions and active status."
        responseCode={listWebhooksResponse}
      />

      <EndpointCard
        method="DELETE"
        path="/v1/webhooks/:id"
        description="Remove a webhook subscription. The endpoint will stop receiving event notifications immediately."
        responseCode={deleteWebhookResponse}
      />
    </div>
  </section>
</DocsLayout>
