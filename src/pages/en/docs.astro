const dedupeExample = `<span class="text-neutral-400 dark:text-neutral-500">// Example: deduplicación con X-Bipbip-Delivery-Id</span>
<span class="text-blue-600 dark:text-blue-400">const</span> processed = <span class="text-blue-600 dark:text-blue-400">new</span> <span class="text-amber-600 dark:text-amber-400">Set</span>();

app.<span class="text-amber-600 dark:text-amber-400">post</span>(<span class="text-green-700 dark:text-green-400">'/v1/order/:remoteId'</span>, <span class="text-blue-600 dark:text-blue-400">async</span> (req, res) =&gt; {
  <span class="text-blue-600 dark:text-blue-400">const</span> deliveryId = req.headers[<span class="text-green-700 dark:text-green-400">'x-bipbip-delivery-id'</span>];

