---
import Layout from '../layouts/Layout.astro';
import { LogoPrimaryDefault } from '../components/icons';
import FloatingIcons from '../components/FloatingIcons.astro';
---

<Layout title="404 — Page Not Found">
  <section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden px-6 py-24">
    <FloatingIcons density="normal" />
    <!-- Background orbs -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/3 top-1/4 h-[400px] w-[500px] rounded-full bg-bipbip-red/[0.06] blur-[120px]"></div>
      <div class="absolute right-1/3 bottom-1/4 h-[300px] w-[400px] rounded-full bg-bipbip-orange/[0.04] blur-[100px]"></div>
    </div>

    <div class="text-center">
      <!-- Big 404 -->
      <p class="text-[8rem] sm:text-[10rem] font-bold leading-none tracking-tighter bg-gradient-to-r from-bipbip-red to-bipbip-orange bg-clip-text text-transparent select-none">
        404
      </p>

      <h1 class="mt-2 text-2xl font-bold text-neutral-900 dark:text-white sm:text-3xl">
        This page took a wrong turn
      </h1>
      <p class="mt-3 text-lg text-neutral-600 dark:text-neutral-400">
        Looks like this route doesn't exist. Maybe the driver got lost?
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-lg bg-bipbip-red px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-bipbip-red/25 transition-all duration-200 hover:bg-bipbip-red-dark hover:-translate-y-0.5"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Back to Home
        </a>
        <a
          href="/docs"
          class="inline-flex items-center gap-2 rounded-lg border border-neutral-300 dark:border-border-dark px-6 py-3 text-sm font-semibold text-neutral-700 dark:text-neutral-300 transition-all duration-200 hover:border-neutral-400 dark:hover:border-neutral-600 hover:-translate-y-0.5"
        >
          View Docs
        </a>
      </div>
    </div>
  </section>
</Layout>
